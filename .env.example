# Pastaay environment configuration template.
# Usage: cp .env.example .env  &&  edit values.

# Web UI auth token
PASTAAY_WEBHOOK_TOKEN=

# AI Oracle API key (OpenAI / Gemini / Anthropic).
PASTAAY_AI_KEY=

# Operator → Engine chaos webhook URL.
# Default: http://pastaay-engine.default.svc.cluster.local:2112/chaos/webhook
PASTAAY_ENGINE_URL=

# Redis broadcast address for multi-node attack fan-out.
# Default: localhost:6380
PASTAAY_REDIS_ADDR=

# Kubernetes namespace for log streamer. Default: default
PASTAAY_NAMESPACE=

# Pod label selector. Empty = all pods. Example: app=myservice
PASTAAY_POD_SELECTOR=